{"step_index":16,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-06-07T18:05:06Z","content":"Created At: 2026-06-07T18:05:06Z\nCompleted At: 2026-06-07T18:05:06Z\nFile Path: `file:///f:/a/biology/src/App.tsx`\nTotal Lines: 126\nTotal Bytes: 4616\nShowing lines 1 to 126\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: /**\n2:  * @license\n3:  * SPDX-License-Identifier: Apache-2.0\n4:  */\n5: \n6: import React, { useState, useEffect } from 'react';\n7: import { motion, AnimatePresence } from 'motion/react';\n8: import { ScreenId } from './types';\n9: import StudentProfileScreen from './components/StudentProfileScreen';\n10: import MainDashboardScreen from './components/MainDashboardScreen';\n11: import UnitsNavigationScreen from './components/UnitsNavigationScreen';\n12: import LessonsListScreen from './components/LessonsListScreen';\n13: import LessonDetailsScreen from './components/LessonDetailsScreen';\n14: import LessonVideoScreen from './components/LessonVideoScreen';\n15: import LessonSummaryScreen from './components/LessonSummaryScreen';\n16: import BiologyQuizScreen from './components/BiologyQuizScreen';\n17: import MinistryExamsScreen from './components/MinistryExamsScreen';\n18: import { Language } from './utils/translations';\n19: \n20: export default function App() {\n21:   const [currentScreen, setCurrentScreen] = useState<ScreenId>(() => {\n22:     // Check if registered, else start on dashboard\n23:     const isRegistered = localStorage.getItem('student_name');\n24:     return isRegistered ? 'main-dashboard' : 'student-profile';\n25:   });\n26:   \n27:   const [transitionDirection, setTransitionDirection] = useState<'forward' | 'backward' | 'none'>('none');\n28:   const [lang, setLang] = useState<Language>(() => {\n29:     return (localStorage.getItem('lang') as Language) || 'ar';\n30:   });\n31:   const [theme, setTheme] = useState(() => {\n32:     return localStorage.getItem('theme') || 'light';\n33:   });\n34: \n35:   useEffect(() => \n<truncated 1539 bytes>\non-video':\n72:         return <LessonVideoScreen onNavigate={handleNavigate} lang={lang} />;\n73:       case 'lesson-summary':\n74:         return <LessonSummaryScreen onNavigate={handleNavigate} lang={lang} />;\n75:       case 'biology-quiz':\n76:         return <BiologyQuizScreen onNavigate={handleNavigate} lang={lang} />;\n77:       case 'ministry-exams':\n78:         return <MinistryExamsScreen onNavigate={handleNavigate} lang={lang} />;\n79:       default:\n80:         return <MainDashboardScreen onNavigate={handleNavigate} lang={lang} />;\n81:     }\n82:   };\n83: \n84:   // Determine sliding offsets matching native mobile animations\n85:   const getVariants = () => {\n86:     if (transitionDirection === 'forward') {\n87:       return {\n88:         initial: { opacity: 0, x: -50 },\n89:         animate: { opacity: 1, x: 0 },\n90:         exit: { opacity: 0, x: 50 }\n91:       };\n92:     } else if (transitionDirection === 'backward') {\n93:       return {\n94:         initial: { opacity: 0, x: 50 },\n95:         animate: { opacity: 1, x: 0 },\n96:         exit: { opacity: 0, x: -50 }\n97:       };\n98:     } else {\n99:       return {\n100:         initial: { opacity: 0 },\n101:         animate: { opacity: 1 },\n102:         exit: { opacity: 0 }\n103:       };\n104:     }\n105:   };\n106: \n107:   const variants = getVariants();\n108: \n109:   return (\n110:     <div className=\"min-h-screen bg-[#f7f9fb] dark:bg-slate-950 w-full overflow-x-hidden relative transition-colors duration-250\">\n111:       <AnimatePresence mode=\"wait\">\n112:         <motion.div\n113:           key={currentScreen}\n114:           initial={variants.initial}\n115:           animate={variants.animate}\n116:           exit={variants.exit}\n117:           transition={{ duration: 0.25, ease: 'easeInOut' }}\n118:           className=\"min-h-screen w-full relative\"\n119:         >\n120:           {renderScreen()}\n121:         </motion.div>\n122:       </AnimatePresence>\n123:     </div>\n124:   );\n125: }\n126: \nThe above content shows the entire, complete file contents of the requested file.\n"}
