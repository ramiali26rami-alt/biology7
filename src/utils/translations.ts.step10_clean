{"step_index":18,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-06-07T18:05:08Z","content":"Created At: 2026-06-07T18:05:08Z\nCompleted At: 2026-06-07T18:05:08Z\nFile Path: `file:///f:/a/biology/src/types.ts`\nTotal Lines: 47\nTotal Bytes: 1471\nShowing lines 1 to 47\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: /**\n2:  * @license\n3:  * SPDX-License-Identifier: Apache-2.0\n4:  */\n5: \n6: export type ScreenId =\n7:   | 'student-profile'    // Screen 1: الملف الشخصي والتسجيل وشراء الباقة\n8:   | 'main-dashboard'     // Screen 2: الواجهة الأساسية للوحة التحكم والإحصائيات\n9:   | 'units-navigation'   // Screen 3: تصفح الوحدات وعدد الدروس فيها\n10:   | 'lessons-list'       // قائمة دروس الوحدة\n11:   | 'lesson-details'     // Screen 5: تفاصيل الدرس والشرح الأكاديمي المنسق\n12:   | 'lesson-video'       // Screen 7: فيديو الدرس التعليمي وفصوله\n13:   | 'lesson-summary'     // Screen 8: ملخص أهم النقاط في الدرس والبطاقات\n14:   | 'biology-quiz'       // Screen 9: اختبار الدرس التفاعلي (صح/خطأ، متعدد)\n15:   | 'ministry-exams';    // Screen 10: نماذج الامتحانات الوزارية مع مؤقت 180 دقيقة\n16: \n17: export interface Lesson {\n18:   id: string;\n19:   title: string;\n20:   progress: number;\n21:   icon: string;\n22:   locked: boolean;\n23:   unit: number;\n24: }\n25: \n26: export interface StudentStats {\n27:   name: string;\n28:   email: string;\n29:   grade: string;\n30:   completionRate: number;\n31:   classRank: string;\n32:   avatarUrl: string;\n33:   premiumUnlocked: boolean;\n34: }\n35: \n36: export interface Question {\n37:   id: number;\n38:   text: string;\n39:   options: {\n40:     key: string;\n41:     text: string;\n42:     name: string;\n43:   }[];\n44:   correctKey: string;\n45:   subjectTitle: string;\n46: }\n47: \nThe above content show